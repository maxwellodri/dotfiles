#!/usr/bin/env bash
# Pi launcher wrapper.
#  - Points Pi at the dotfiles-managed config dir (no symlinks needed).
#  - Keeps runtime junk (sessions, packages, trust, logs) out of the repo.
#  - Paints a gruvbox-dark canvas for pi's duration: OSC 11 sets the pane
#    default bg, which pi clears/fills its inter-panel gaps with; OSC 111
#    restores the original on exit. Per-pane in tmux (verified), so other
#    panes and the wezterm window are never affected.
#  - Reads the z.ai API key from pass; the value never touches disk/history.
#
# Subcommands (update/list/install/...) and --help/--version are exec'd straight
# through (they need no key/session/canvas and must stay argv[1]); the normal
# coding-agent invocation is run as a child so the EXIT trap can reset the bg.
set -euo pipefail

: "${dotfiles:?pi wrapper: \$dotfiles is not set (source your shell rc).}"

export PI_CODING_AGENT_DIR="$dotfiles/pi"
export PI_CODING_AGENT_SESSION_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/pi/sessions"
mkdir -p "$PI_CODING_AGENT_SESSION_DIR"

PI_BIN="${PI_BIN:-$HOME/.local/bin/pi}"

# pi's subcommands and the help/version flags must be argv[1] to be recognized;
# prepending --session-dir (or anything else) demotes them into agent prompts
# (e.g. 'pi list' would launch the AI with "list" as the prompt). They also need
# no API key, session dir, or themed canvas, so exec them through untouched.
# PI_CODING_AGENT_DIR is still exported above so list/config/update manage the
# dotfiles-managed extensions rather than the default location.
case "${1:-}" in
	install|remove|uninstall|update|list|config|--help|-h|--version|-v)
		exec "$PI_BIN" "$@" ;;
esac

# API key from pass. Evaluated here only; passed to pi via its env.
if ! ZAI_API_KEY="$(pass zai_pi_api_key)"; then
	echo "pi wrapper: failed to read 'zai_pi_api_key' from pass" >&2
	exit 1
fi

# Gruvbox canvas for pi's duration. Clear the screen before (so the bg
# repaint is clean, no leftover lines from the shell) and after (so the
# restored bg doesn't show pi's exit artifacts / scrollback streaks).
if [ -t 1 ]; then
	clear
	# shellcheck disable=SC1003
	printf '\033]11;#282828\033\\'
	trap 'clear; printf "\033]111\033\\"' EXIT INT TERM
fi

# Run pi (child, not exec) so the trap fires on its return. Pass --session-dir
# explicitly (highest precedence; reliable across pi versions).
ZAI_API_KEY="$ZAI_API_KEY" "$PI_BIN" --session-dir "$PI_CODING_AGENT_SESSION_DIR" "$@"
