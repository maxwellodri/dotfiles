#!/usr/bin/env bash
DOWNLOAD_DIRS=("$HOME/Downloads/asm/")

batch_mode=0
if [[ $1 == "--batch" ]]; then
    batch_mode=1
    shift
fi

if [[ -n $WAYLAND_DISPLAY ]]; then
    dmenu=dmenu-wl
elif [[ -n $DISPLAY ]]; then
    dmenu=dmenu
else
    echo "Error: No Wayland or X11 display detected" >&2
    exit 1
fi

selected_dir=$(printf '%s\n' "Keep Default Dir" "${DOWNLOAD_DIRS[@]}" | "$dmenu" -l 30 -c --class "tsp_ytdlp_dir" -p "Download Directory:")

[[ -n $selected_dir ]] || exit 0

dir_args=()
if [[ $selected_dir != "Keep Default Dir" ]]; then
    dir_args=(--dir "$selected_dir")
fi

if [[ $batch_mode -eq 1 ]]; then
    while IFS= read -r url; do
        [[ -n $url ]] && tsp_ytdlp add "$url" "${dir_args[@]}"
    done <<< "$1"
else
    tsp_ytdlp add "$1" "${dir_args[@]}"
fi
