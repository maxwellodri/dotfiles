#!/bin/bash

IDLE_THRESHOLD=$(( ${1:-120} * 60000 ))

trap 'exit 1' INT
POLL_INTERVAL=${POLL_INTERVAL:-60}        # seconds between checks

while true; do
  idle=$(xprintidle)
  if [ "$idle" -gt "$IDLE_THRESHOLD" ]; then
    notify-send "AFK detected" "Idle for $(( idle / 1000 ))s"
    sleep 5
    [ "$(xprintidle)" -gt "$IDLE_THRESHOLD" ] && exit 0 || exit 1
  fi
  sleep "$POLL_INTERVAL"
done
