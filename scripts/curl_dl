#!/usr/bin/env bash

while [[ $# -gt 0 ]]; do
  case "$1" in
    --file) FILE="$2"; shift 2 ;;
    --url)  URL="$2";  shift 2 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$FILE" ]] || [[ -z "$URL" ]]; then
  echo "Usage: $(basename "$0") --file <file> --url <url>" >&2
  exit 1
fi

START=$(date +%s)
until curl -L -C - -o "$FILE" "$URL"; do echo "Retrying..."; sleep 2; done
ELAPSED=$(( $(date +%s) - START ))

format_duration() {
  local s=$1
  if (( s < 60 )); then printf "%ds" "$s"
  elif (( s < 3600 )); then printf "%dm %ds" "$((s / 60))" "$((s % 60))"
  else printf "%dh %dm" "$((s / 3600))" "$(( (s % 3600) / 60 ))"
  fi
}

BODY="Downloaded in ($(format_duration $ELAPSED))"
if [[ -n "$TMUX" ]]; then
  SESSION=$(tmux display-message -p '#S')
  BODY="$BODY in tmux session '$SESSION'"
fi

herald message --title "Download complete" --sound "$BODY"
