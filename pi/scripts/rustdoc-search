#!/usr/bin/env bash
#
# rustdoc-search — fetch a single Rust item's docs from docs.rs as compact markdown.
#
# Retrieval primitive designed for LLM/subagent consumption: ~hundreds of tokens
# per item instead of the ~tens of thousands a whole-crate dump costs.
#
#   rustdoc-search <crate>                      # list root module contents
#   rustdoc-search <crate> <ItemPath>           # render one item (docs + signature + members)
#   rustdoc-search serde Deserialize
#   rustdoc-search serde de::Deserializer
#   rustdoc-search serde de                     # list a submodule's contents
#   rustdoc-search tokio spawn --version 1.45
#
# ItemPath is a Rust path using `::`, with or without the leading crate name.
# Matching is by path suffix against the rustdoc-JSON path table, so
# `Deserialize` and `serde::de::Deserialize` both work.
#
# JSON is cached at $RUSTDOC_CACHE (default /tmp/pi-rust-docs). Use --refresh to
# re-download. Requires curl, jq, gunzip.

set -euo pipefail

cache="${RUSTDOC_CACHE:-/tmp/pi-rust-docs}"
version="latest"
refresh=0
raw=0
# rustdoc JSON format_version range these jq queries are verified to handle
# (tested across fv57, fv59, fv60; fv58 is inferred-stable between 57 and 59).
min_supported_format_version=57
max_supported_format_version=60

usage() {
    cat <<'EOF'
Usage: rustdoc-search [OPTIONS] <crate> [item-path]

Fetch a Rust item's docs from docs.rs as compact markdown.

Arguments:
  <crate>        Crate name, e.g. serde, tokio
  <item-path>    Optional Rust path (serde::de::Deserializer or just Deserializer).
                 Omit to list the crate's root module contents.

Options:
  -V, --version <V>  Crate version or semver (default: latest)
  -r, --refresh      Re-download the rustdoc JSON, ignoring cache
  --raw              Dump the resolved item's full inner JSON (for deep type info)
  -h, --help         Show this help

Env:
  RUSTDOC_CACHE      Cache directory (default: /tmp/pi-rust-docs)
EOF
    exit 0
}

die() { echo "Error: $*" >&2; exit 1; }

positional=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -V|--version) version="${2:-}"; [[ -n "$version" ]] || die "--version requires a value"; shift 2 ;;
        -r|--refresh) refresh=1; shift ;;
        --raw)        raw=1; shift ;;
        -h|--help)    usage ;;
        -*)           die "Unknown option: $1" ;;
        *)            positional+=("$1"); shift ;;
    esac
done

[[ ${#positional[@]} -ge 1 ]] || die "No crate provided. See --help."
crate="${positional[0]}"
item="${positional[1]:-}"

for cmd in curl jq gunzip; do
    command -v "$cmd" >/dev/null 2>&1 || die "$cmd is not installed"
done

# Hardcoded exception: the `bevy` crate is an umbrella that only re-exports
# from per-domain sub-crates (bevy_app, bevy_ecs, ...), so a bare root listing
# is a single useless `bevy_internal` import. Short-circuit before fetching
# its JSON and point at the right sub-crate instead. (With an item path,
# `rustdoc-search bevy App` is already routed correctly by the external
# re-export branch below.)
if [[ "$crate" == "bevy" ]]; then
    cat <<'EOF'
# bevy — umbrella crate (no items of its own)

The `bevy` crate is an umbrella that only re-exports from per-domain
sub-crates, so its root has nothing to list. Search the specific sub-crate
instead. Modules map to crates as `bevy::<m>` → `bevy_<m>`:

  bevy::app       → bevy_app
  bevy::ecs       → bevy_ecs
  bevy::math      → bevy_math
  bevy::transform → bevy_transform
  bevy::render    → bevy_render
  bevy::asset     → bevy_asset

Examples:
  rustdoc-search bevy_app App
  rustdoc-search bevy_ecs                       # list bevy_ecs's root
  rustdoc-search bevy_ecs world::World

For a `bevy::<module>::<Item>` path: drop `bevy::`, prefix the module with
`bevy_`, and search that crate.
EOF
    exit 0
fi

# Resolve "latest" to a concrete version for a stable cache key.
if [[ "$version" == "latest" ]]; then
    resolved=$(curl -s -H "User-Agent: rustdoc-search" "https://crates.io/api/v1/crates/${crate}" \
        | jq -r '.crate.max_version // empty' 2>/dev/null) || resolved=""
    [[ -n "$resolved" ]] && version="$resolved"
fi

mkdir -p "$cache"
json="${cache}/${crate}_${version}.json"

if [[ ! -f "$json" || "$refresh" -eq 1 ]]; then
    # Fetch the un-pinned default JSON: docs.rs serves whatever rustdoc JSON
    # format_version a crate's build emitted, and that varies per build (older
    # builds are 57; recent ones 59/60). Pinning a single fv 404s/500s for every
    # build that emits a different one, so take the default and validate its
    # format_version field against the supported range below.
    url="https://docs.rs/crate/${crate}/${version}/json.gz"
    code=$(curl -sL -w "%{http_code}" -o "${json}.tmp" "$url" || true)
    if [[ "$code" != "200" ]]; then
        rm -f "${json}.tmp"
        # No HTTP response at all => network/DNS, not a docs.rs signal.
        if [[ "$code" == "000" ]]; then
            die "Couldn't reach docs.rs for ${crate} ${version} (no HTTP response — likely a network/DNS error). Retry; if only docs.rs is affected, fall back to websearch or curl."
        fi
        # No JSON at all => nonexistent crate/version or pre-2025-05-23 build.
        die "No rustdoc JSON for ${crate} ${version} (HTTP ${code}); crate/version may not exist, or predates docs.rs JSON builds (releases before 2025-05-23 have none). Fallback (schema-independent): use websearch or curl to fetch this crate's docs another way."
    fi
    gunzip -c "${json}.tmp" > "${json}" 2>/dev/null || { rm -f "${json}.tmp"; die "Failed to decompress rustdoc JSON from ${url}."; }
    rm -f "${json}.tmp"

    # Tripwire: docs.rs emits per-build format_versions (there is no single
    # "current" fv), so validate the served schema against the range the jq
    # queries are known to handle. Unlike the old fv-pinned probe — which guessed
    # at the next version and could false-positive on a transient 500 — this
    # reports the REAL number and fires only on a genuinely unknown schema.
    fv=$(jq -r '.format_version // empty' "$json")
    if [[ -z "$fv" ]] || (( fv < min_supported_format_version || fv > max_supported_format_version )); then
        rm -f "$json"   # don't cache an unsupported schema
        die "docs.rs served rustdoc JSON format_version ${fv:-unknown} for ${crate} ${version}; this script handles ${min_supported_format_version}–${max_supported_format_version}. Inform the user to update this script (raise max_supported_format_version and re-verify the jq). Fallback (schema-independent): use websearch or curl to fetch this crate's docs another way."
    fi
fi

# Resolve this crate's numeric id (rustdoc convention: 0, but derive it).
crate_id=$(jq -r '.paths[.root|tostring].crate_id // 0' "$json")

# ---- No item given: list the root module's direct children. ----
if [[ -z "$item" ]]; then
    jq -r '
        . as $r | ($r.index[$r.root|tostring].inner.module.items // []) as $kids
        | "# module \($r.paths[$r.root|tostring].path | join("::"))  \($kids|length) items\n\n"
        + ([$kids[] | tostring as $id | $r.index[$id] as $c
            | ( if $c.inner.use then
                  "- import: \($c.inner.use.name)  _(from \($c.inner.use.source))_"
                else
                  ($r.paths[$id] // {kind:"?", path:[$c.name // "?"]})
                  | "- \(.kind): \(.path|join("::"))"
                end )] | join("\n"))
    ' "$json"
    exit 0
fi

# ---- Resolve item path → id. Two stages, then a `pub use` fallback:
#   1. Exact canonical path  <crate>::<item>  — disambiguates a same-named
#      macro/trait from the crate-root module (e.g. `quote quote` → the
#      `quote!` macro at `quote::quote`, not the root module `quote`).
#   2. Suffix match  <item>  within this crate — catches items nested in
#      submodules when you don't know the full path (e.g. `serde Deserialize`
#      → `serde::de::Deserialize`); lenient about a leading crate-name segment.
#   3. Follow a `pub use` whose imported name == last segment (re-exports).
# `<crate>` with no item lists the root module instead of resolving.
mapfile -t segs <<< "${item//::/$'\n'}"
segs_json=$(printf '%s\n' "${segs[@]}" | jq -R . | jq -s .)

resolve=$(jq --argjson segs "$segs_json" --argjson cid "$crate_id" --arg crate "$crate" -r '
    $segs as $suffix
    | ([ $crate ] + $suffix) as $full
    | (.paths | to_entries | map(select(.value.crate_id == $cid))) as $mine
    | ($mine | map(select(.value.path == $full))) as $exact
    | (if ($exact | length) >= 1 then $exact
       else $mine | map(select(.value.path[-($suffix|length):] == $suffix)) end) as $hits
    | if   ($hits | length) == 0 then "NONE"
      elif ($hits | length) == 1 then $hits[0].key
      else "AMBIG\n" + ($hits | map("  " + (.value.path | join("::")) + "  [" + .value.kind + "]") | join("\n"))
      end
' "$json")

case "$resolve" in
    NONE)
        # Fallback: follow `pub use` re-exports whose imported name == last segment.
        last_seg="${segs[-1]}"
        resolve=$(jq --arg last "$last_seg" -r '
            .index | to_entries
            | map(select(.value.inner.use.name == $last) | .value.inner.use.id)
            | unique
            | if   length == 1 then (.[0]|tostring)
              elif length > 1  then "AMBIG\n" + (map(tostring)|join(", "))
              else "NONE" end
        ' "$json")
        ;;
esac
case "$resolve" in
    NONE) die "No item matching '$item' in $crate $version. Run 'rustdoc-search $crate' to see what's available." ;;
    AMBIG*) echo "Error: '$item' is ambiguous in $crate $version:" >&2; echo "${resolve#AMBIG}" >&2; exit 1 ;;
esac
id="$resolve"

# External re-exports point outside this crate's .index. Detect and point instead.
if ! jq --arg id "$id" -e '.index[$id] != null' "$json" >/dev/null 2>&1; then
    src=$(jq --arg id "$id" -r '
        .index | to_entries[] | select((.value.inner.use.id // -1) == ($id|tonumber))
        | .value.inner.use.source // empty' "$json" | head -1)
    if [[ -n "$src" ]]; then
        ext="${src%%::*}"
        echo "# (external re-export) $item"
        echo
        echo "Resolves to \`$src\`, defined in crate **$ext**."
        echo "Its docs are not in $crate's rustdoc JSON — fetch the defining crate:"
        echo
        echo "  rustdoc-search $ext ${src#*::}"
        exit 0
    fi
    die "Resolved id $id is not in $crate's index and no re-export source was found."
fi

if [[ "$raw" -eq 1 ]]; then
    jq --arg id "$id" '.index[$id] | {name, docs, inner}' "$json"
    exit 0
fi

# ---- Render the item as compact markdown, dispatching on kind. ----
jq --arg id "$id" -r '
    . as $r | $r.index[$id] as $it | $it.inner as $inner
    | ($inner | keys[0]) as $kind
    | ($r.paths[$id].path // [$it.name] | join("::")) as $fqp
    | "# \($kind) \($fqp)\n\n"
      + (($it.docs // "") | rtrimstr("\n"))
      + (if ($it.docs // "") != "" then "\n\n" else "" end)
      + (
          if $kind == "module" then
              "## Contents\n" +
              ( [($inner.module.items // [])[] | tostring as $cid | $r.index[$cid] as $c
                  | ( if $c.inner.use then
                        "- import: \($c.inner.use.name)  _(from \($c.inner.use.source))_"
                      else
                        ($r.paths[$cid] // {kind:"?", path:[$c.name // "?"]})
                        | "- \(.kind): \(.path|join("::"))"
                      end )] | join("\n") )
          elif $kind == "trait" then
              "## Methods\n" +
              ( [($inner.trait.items // [])[] | tostring as $mid | $r.index[$mid] as $m
                  | "- \($m.name)\(if ($m.inner.function.has_body == false) then "  _(required)_" else "" end)"]
                | join("\n") )
          elif $kind == "struct" then
              ($inner.struct.fields // {}) as $f
              | "## Fields\n" +
              ( if   ($f|has("Named")) then [ $f.Named[] | "- \(.name)" ] | join("\n")
                elif ($f|has("Plain")) then "- (\($f.Plain|length) unnamed, tuple)"
                else "- (unit, no fields)" end )
          elif $kind == "enum" then
              "## Variants\n" +
              ( [($inner.enum.variants // [])[] | tostring as $vid | $r.index[$vid].name // "?"]
                | map("- \(.)") | join("\n") )
          elif $kind == "function" then
              ($inner.function) as $fn
              | "## Signature\n```\nfn \($it.name)"
                + (if ($fn.generics.params | length) > 0
                   then "<" + ([$fn.generics.params[].name]|join(", ")) + ">" else "" end)
                + "(" + ([$fn.sig.inputs[] | .[0]] | join(", ")) + ")\n```"
          else "# \($kind) (no specific renderer; use --raw)" end
        )
' "$json"

################################################################################
# NOTES ON UPDATING — rustdoc JSON format_version handling
# (Updated for json v58 incident; this script now handles fv 57–60)
################################################################################
#
# HOW docs.rs SERVES JSON (the key model)
#   docs.rs serves whatever rustdoc JSON format_version a crate's BUILD emitted —
#   there is NO single global "current" fv. At the same time, different crates
#   sit on different fvs because they were last rebuilt with different toolchains:
#     fv57 : bevy, bevy_ecs, serde, reqwest, sqlx, pyo3, nalgebra, tracing
#     fv59 : egui, anyhow
#     fv60 : tokio, clap, axum, wgpu, rand
#   (as of 2026-07; no fv58 crates were observed in the wild.)
#
# WHY WE DON'T PIN A SINGLE fv (the v58 lesson)
#   An earlier version pinned `supported_format_version=57` in the URL. Pinning
#   ANY single fv 404s/500s for every build that emits a different one, so a pin
#   to 58 would have broken the fv57 crates AND the fv59/60 crates. Worse, the
#   old tripwire guessed "58+ is now available" via `$((57+1))+` without ever
#   verifying fv58 existed — a transient HTTP 500 on the pinned fv57 URL for
#   bevy_app 0.19.0 set off a FALSE alarm that prompted this rewrite. (bevy_app
#   0.19.0 fv57 was 10/10 → HTTP 200 minutes later; the 500 was transient.)
#   => Current design: fetch the un-pinned default `.json.gz`, then validate the
#      JSON's own `.format_version` against [min, max]_supported_format_version.
#      The tripwire now reports the REAL number and fires only on a genuinely
#      unknown schema. DO NOT reintroduce a single pinned fv.
#
# WHEN TO UPDATE
#   Bump `max_supported_format_version` (and re-verify the jq) the day a crate's
#   default JSON reports a format_version ABOVE the current max (the tripwire's
#   message names the exact number). `min` may rise if old fvs disappear from
#   docs.rs, but that hasn't happened — fv57 builds are still served.
#
# CHECKING THE CURRENT HIGH-WATER fv
#     for cr in tokio/latest clap/latest axum/latest wgpu/latest rand/latest \
#               egui/latest anyhow/latest bevy_ecs/latest serde/latest; do
#       curl -sL "https://docs.rs/crate/$cr/json.gz" | gunzip -c \
#         | jq -r '"\($cr) -> fv\(.format_version)"'
#     done
#
# DOES THE jq NEED CHANGES? (usually NO)
#   The schema for the fields this script reads has been stable across fv57–60,
#   verified by running every renderer (module / trait / struct / enum / function
#   signature) + path resolution + `pub use` re-export resolution against crates
#   of each fv. The fields in play are deep, old, structural ones:
#       .format_version  .root  .paths[]  .index[]  .paths[id].crate_id/.kind/.path
#       .inner.<module|trait|struct|enum|function|use>  (kind = keys(inner)[0])
#       .inner.module.items  .inner.trait.items  .inner.enum.variants
#       .inner.struct.fields.{Named,Plain}
#       .inner.function.{generics.params[].name, sig.inputs[], has_body}
#       .inner.use.{name, source, id}
#   So a typical bump is just raising `max_supported_format_version`. Only if a
#   renderer mis-renders on the new fv do you need to touch jq — re-run the
#   verification matrix below against the new fv and fix what breaks.
#
# VERIFICATION MATRIX (run against crates of EACH in-scope fv)
#     rustdoc-search serde   Deserialize        # trait      (fv57)
#     rustdoc-search serde                       # root list  (fv57)
#     rustdoc-search egui    Context            # struct     (fv59)
#     rustdoc-search tokio   spawn              # function   (fv60)
#     rustdoc-search tokio                       # root list  (fv60)
#     rustdoc-search <crate> <module>::<Item>   # path resolution + `pub use`
#     rustdoc-search <bad-item>                 # error path
#     rustdoc-search <missing-crate>            # HTTP-error path
#
# UPSTREAM SCHEMA REFERENCE
#   The format_version constant and its per-version CHANGELOG live in the
#   rust-lang/rust tree: src/rustdoc-json-output/ (see FORMAT_VERSION and the
#   CHANGELOG.md there). When a new fv lands, diff that CHANGELOG against the
#   fields listed above to predict whether any jq needs adapting.
