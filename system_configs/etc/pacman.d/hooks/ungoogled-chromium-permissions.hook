[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = ungoogled-chromium-bin

[Action]
Description = Fix restrictive permissions on ungoogled-chromium binaries
When = PostTransaction
Exec = /bin/bash -c 'chmod 755 /usr/bin/chromium /usr/bin/chromedriver && chmod -R o+rX /usr/lib/chromium/'
