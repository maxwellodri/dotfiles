{
    "$schema": "https://opencode.ai/config.json",
    "disabled_providers": ["openai", "gemini", "anthropic"],
    "model": "zai-coding-plan/glm-5.1",
    "username": "maxwell",
    "permission": {
        "edit": "allow",
        "bash": {
            "default": "ask",
            "gh": "allow"
        },
        "webfetch": "ask",
        "doom_loop": "ask",
        "external_directory": {
            "~/.local/share/cargo/*": "allow",
            "~/.local/share/nvim/*": "allow"
        }
    },
    "agent": {
        "plan": {
            "model": "zai-coding-plan/glm-5.1",
            "tools": {
                "web_search_prime": true
            },
            "permission": {
                "webfetch": "allow"
            }
        },
        "build": {
            "model": "zai-coding-plan/glm-5.1"
        }
    },
    "formatter": {
        "rustfmt": {
            "command": ["rustfmt", "--edition", "2024", "$FILE"],
            "extensions": [".rs"]
        }
    },
    "lsp": {
        "rust-analyzer": {
            "disabled": true
        }
    },
    "mcp": {
        "web-search-prime": {
            "type": "remote",
            "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
            "enabled": false,
            "headers": {
                "Authorization": "Bearer {env:ZAI_MCP_API_KEY}"
            }
        }
    }
}
